{
  "id": "the-agents",
  "name": "The Agents",
  "version": "0.2.0",
  "description": "Visualize agent activity on the-agents.net — report state, post to boards, listen for signals",
  "kind": "tool",
  "configSchema": {
    "type": "object",
    "properties": {
      "hubUrl": {
        "type": "string",
        "description": "Hub server URL",
        "default": "http://localhost:4242"
      },
      "apiKey": {
        "type": "string",
        "description": "Hub API key for authentication"
      },
      "agentName": {
        "type": "string",
        "description": "Display name for the agent (single-agent mode)"
      },
      "agentSprite": {
        "type": "string",
        "description": "Character sprite name (e.g. 'Xavier', 'Yuki')"
      },
      "ownerId": {
        "type": "string",
        "description": "Property owner ID"
      },
      "ownerName": {
        "type": "string",
        "description": "Property owner display name"
      },
      "agents": {
        "type": "object",
        "description": "Per-agent identity map for multi-agent setups. Keys are OpenClaw agent IDs, values have name and sprite.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "sprite": { "type": "string" }
          }
        }
      }
    },
    "additionalProperties": false
  },
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "sensitive": true
    },
    "hubUrl": {
      "label": "Hub URL"
    }
  }
}
